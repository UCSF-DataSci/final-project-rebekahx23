# Required for Google ADK model calls
GOOGLE_API_KEY=your_google_api_key_here

# Data source (use a read-only DB user)
DQ_DB_URL=sqlite:///./demo_data_quality.db

# Runtime settings
DQ_MODEL=gemini-2.5-flash
DQ_LOG_DIR=./runs
DQ_REPORT_BRAND_NAME=UCSF
DQ_REPORT_LOGO_URL=../assets/ucsf_logo.svg
DQ_SAMPLE_SIZE=20
DQ_SAMPLE_BATCHES=3
DQ_PROFILE_TOKEN_CAP=0
DQ_QUERY_ROW_LIMIT=200
DQ_MAX_TESTS=12